# Database for docker-compose and local env loading
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=rex_booking
MYSQL_USER=rex
MYSQL_PASSWORD=rex123
MYSQL_PORT=3307

# Backend database env
DB_HOST=mysql
DB_PORT=3306
DB_NAME=rex_booking
DB_USER=rex
DB_PASSWORD=rex123

# Optional full Spring datasource override
# SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/rex_booking?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
# SPRING_DATASOURCE_USERNAME=rex
# SPRING_DATASOURCE_PASSWORD=rex123
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# Railway sample
# Source URL:
# mysql://root:NDBXuUVGUdfiFrWAFdApudVPagAphpgc@gondola.proxy.rlwy.net:45979/railway
# JDBC for Spring:
# SPRING_DATASOURCE_URL=jdbc:mysql://gondola.proxy.rlwy.net:45979/railway?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=NDBXuUVGUdfiFrWAFdApudVPagAphpgc
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# Optional JPA tuning
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_JPA_SHOW_SQL=false
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true

# App config
APP_JWT_SECRET=REPLACE_WITH_AT_LEAST_32_CHARACTERS_SECRET_KEY_REX_2026
APP_CORS_ALLOWED_ORIGINS=*
JAVA_OPTS=-Xms256m -Xmx512m

# Production profile
SPRING_PROFILES_ACTIVE=prod
